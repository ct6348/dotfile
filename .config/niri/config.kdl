// ────────────── Window Rules ──────────────
// https://github.com/YaLTeR/niri/wiki/Configuration:-Window-Rules

// 定义所有窗口样式
// window-rule {
//   geometry-corner-radius 5
//
//   clip-to-geometry false
// }

// 定义打开就全屏的应用好
window-rule {
    match app-id="firefox"
    match app-id="CherryStudio"
    // match app-id="brave"
    match app-id="com.mitchellh.ghostty"
    // open-on-workspace "1:worka"
    match app-id="com.lite_xl.LiteXL"
    match app-id="jetbrains-idea"
    match app-id="com.freerdp.client.sdl3"
    match app-id="Reasonix"
    match app-id="obsidian"
    match app-id="org.gnome.Nautilus"
    open-focused true
    open-floating false // Always float Firefox PiP windows
    // open-maximized true  // 四周有一点空隙()
    open-maximized-to-edges true // 四周无空隙
    opacity 0.9
}

window-rule {
  match app-id="chromium"
  open-focused true
  open-floating false // Always float Firefox PiP windows
  opacity 0.9
}

