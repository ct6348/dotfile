// Indicate screencasted windows with red colors.
window-rule {
  // 匹配脚本中定义的 app-id
    match app-id="alacritty-dropdown"
    
    // 核心配置：设为浮动，不参与平铺逻辑
    open-floating true
    // match is-window-cast-target=true
    
    //match app-id="dev.zed.Zed"
    match title="inner-embed"
    // match app-id=r#"^noctalia"#
    // match is-active-in-column=true
    // open-maximized-to-edges true
    // open-on-workspace "chat"

    // match is-active=true
    // match is-focused=false
    // match is-active-in-column=true // 在当前列中打开
    // match is-floating=true
    // match is-window-cast-target=true
    // default-column-display "tabbed"

    // focus-ring {
    //     active-color "#f38ba8"
    //     inactive-color "#7d0d2d"
    // }
    //
    // border {
    //     inactive-color "#7d0d2d"
    // }
    //
    // shadow {
    //     color "#7d0d2d70"
    // }
    //
    // tab-indicator {
    //     active-color "#f38ba8"
    //     inactive-color "#7d0d2d"
    // }
    // default-window-height { fixed 360; }
    // default-floating-position x=10 y=30 relative-to="bottom-right"
    // default-floating-position x=0 y=0 relative-to="top-left"
    
    default-floating-position x=0 y=0 relative-to="top"
    opacity 0.60
    default-column-width { proportion 1.0; }
    default-window-height { proportion 0.50; }
}
// ────────────── Layout Settings ──────────────
// https://github.com/YaLTeR/niri/wiki/Configuration:-Layout

layout {
    gaps 5 // Gap between windows
    center-focused-column "never" // Don’t auto-center focused column

    preset-column-widths {
        proportion 0.5
        proportion 0.75
        proportion 1.0
        proportion 0.25
    }

    preset-window-heights {
        proportion 0.5
        proportion 0.75
        proportion 1.0
        proportion 0.25
    }
    
    // default-column-display "tabbed"
    // default-column-display "normal"

    // >>>>>>>>>>>>>>>>>>>
    // You may also want to hide the tab indicator
    // when there's only a single window in a column.
    // tab-indicator {
    //     hide-when-single-tab
    // }
    // <<<<<<<<<<<<<<<<<<<

    default-column-width { proportion 0.5; } // 0.5是默认值，半个屏幕宽度

    focus-ring {
        width 3
        active-color "#7D5FFF"
        // active-color "#12131B"
        inactive-color "#505050"
    }

    // shadow {
    //     softness 30
    //     spread 5
    //     offset x=0 y=5
    //     color "#0007"
    // }

    struts {}

}

// This minimal configuration allows you to have a blurred and dimmed copy of your wallpaper that appears only in Niri’s overview.
layer-rule { //壁纸
    match namespace="^noctalia-overview*"
    place-within-backdrop true
}// `niri msg layers`显示有namespace

