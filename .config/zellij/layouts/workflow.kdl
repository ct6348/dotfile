layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    
    tab name="Main" focus=true {
        pane split_direction="horizontal" {
            pane size="70%" {
                pane name="Editor"
            }
            pane split_direction="vertical" size="30%" {
                pane name="Files" {
                    plugin location="file_manager"
                }
                pane name="Terminal"
            }
        }
    }
    
    tab name="Git" {
        pane split_direction="vertical" {
            pane name="Status" command="git" {
                args "status"
            }
            pane name="Log" command="git" {
                args "log" "--oneline" "--graph" "-10"
            }
        }
    }
    
    tab name="Monitor" {
        pane split_direction="horizontal" {
            pane name="System" command="htop" size="50%"
            pane split_direction="vertical" size="50%" {
                pane name="Network" command="ss" {
                    args "-tulpn"
                }
                pane name="Disk" command="df" {
                    args "-h"
                }
            }
        }
    }
}

keybinds {
    shared {
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt g" { Run "git" "status"; }
        bind "Alt f" { Run "fd" "."; }
        bind "Alt r" { Run "rg" "."; }
    }
}
